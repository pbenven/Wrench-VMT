# Vehicle Maintenance Tracker — Environment Configuration
# Copy this file to .env and adjust values as needed.
# Both POSTGRES_PASSWORD and PGPASSWORD must match.

POSTGRES_USER=your-username
POSTGRES_PASSWORD=your-password
POSTGRES_DB=vehicle_maintenance_db

PGUSER=your-username
PGPASSWORD=your-password
PGDATABASE=vehicle_maintenance_db
PGHOST=db
PGPORT=5432
